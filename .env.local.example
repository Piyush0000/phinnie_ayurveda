# =====================================================================
# Thinnie Aurvadic — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit
# the populated `.env.local`.
#
# Quick start:
#   1) Generate a strong NextAuth secret:
#        openssl rand -base64 32
#      (on Windows: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`)
#   2) Set MONGODB_URI from MongoDB Atlas → Connect → Drivers → Node.
#   3) Razorpay test keys: Razorpay Dashboard → Settings → API Keys → Generate Test Keys.
#      Webhook secret: Razorpay Dashboard → Settings → Webhooks → Add Webhook.
#   4) Cloudinary: Cloudinary Dashboard → Settings → Access Keys.
#   5) Resend: resend.com → API Keys (production also needs a verified sender domain).
#
# All variables NOT prefixed with NEXT_PUBLIC_ are server-only and never reach the browser.
# =====================================================================

# --- MongoDB Atlas (REQUIRED) ----------------------------------------
# Connection string for the primary database. Without this the app boots
# but every DB-backed page shows a not-configured notice.
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/thinnie_aurvadic?retryWrites=true&w=majority"

# --- NextAuth (REQUIRED for auth) ------------------------------------
# Used to sign session JWTs. MUST be a 32+ byte random secret in production.
# Generate: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
# In production set this to your fully-qualified canonical domain.
# Example: "https://thinnieaurvadic.com"
NEXTAUTH_URL="http://localhost:3000"

# --- Razorpay (REQUIRED for checkout) --------------------------------
# Server-only secrets — DO NOT prefix with NEXT_PUBLIC_.
# RAZORPAY_KEY_ID is sent to the browser only at checkout time, in the
# /api/payment/create-order response.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
# Webhook secret: configure the SAME value in the Razorpay dashboard
# webhook settings. Used by /api/webhook/razorpay to verify event authenticity.
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# --- Cloudinary (REQUIRED for product image upload) -------------------
# Used by the admin /api/upload endpoint and ImageUploader component.
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# --- Resend Email (optional but recommended) -------------------------
# Without RESEND_API_KEY, transactional emails (welcome, order confirmation,
# shipping, delivery) are silently skipped — the app still functions.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"
# The sender displayed in email headers. The domain must be verified in
# Resend before production sends will be delivered. Until verified, the
# app falls back to onboarding@resend.dev (Resend's test sender).
EMAIL_FROM="Thinnie Aurvadic <orders@thinnieaurvadic.com>"

# --- Google OAuth (optional) -----------------------------------------
# Leave blank to disable Google sign-in. If filled, "Sign in with Google"
# is enabled automatically by lib/auth.ts.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Upstash Redis (recommended for production rate limiting) --------
# When both vars are set, lib/rate-limit.ts uses Upstash so quotas are
# enforced consistently across Vercel serverless instances. When unset,
# the limiter falls back to per-instance in-memory state (fine for local
# dev, NOT sufficient as a real abuse mitigation in production).
# Get these from https://console.upstash.com → Redis → REST API.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Public app URL --------------------------------------------------
# Used by sitemap.ts, robots.ts, app/layout.tsx (metadataBase), and email
# templates. Set to https://yourdomain.com (no trailing slash) in prod.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin seeding (used by `npm run seed`) --------------------------
# These bootstrap the first admin user. ADMIN_PASSWORD is REQUIRED by the
# seed script — it has no default, so a forgotten value can never silently
# create a weak credential. Choose a strong password (8+ chars) and rotate
# it via /admin or the database after the first deploy.
ADMIN_EMAIL="admin@thinnieaurvadic.com"
ADMIN_PASSWORD="set-a-strong-password-before-running-npm-run-seed"
