{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./*"] }
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": { "module": "commonjs" }
  },
  "include": ["scripts/**/*.ts", "models/**/*.ts", "lib/**/*.ts"]
}
